# =========================================================================
# HMK Eyewear Backend Environment Variables - EXAMPLE
# =========================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to Git!

# --- Database ---
DATABASE_URL=jdbc:mysql://localhost:3306/hmk_eyewear_dev?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Ho_Chi_Minh
DATABASE_USERNAME=root
DATABASE_PASSWORD=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=your-secret-key-here-min-256-bits
JWT_EXPIRATION_MS=604800000

# --- Email (SMTP) ---
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
